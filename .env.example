PORT=8080
TMDB_API_KEY=replace-with-tmdb-api-key
CHAT_API_BASE=https://chat-api.watchbilm.org
DATA_API_BASE=https://data-api.watchbilm.org
BILM_ADMIN_EMAILS=watchbilm@gmail.com
BILM_OPS_TOKEN=replace-with-strong-random-token

# Supabase mirror (write-only backup storage; Cloudflare remains primary)
# This BILM server reads SUPABASE_PROJECT_URL + SUPABASE_SERVICE_ROLE_KEY.
# Put your real values in a local .env file, not in git.
SUPABASE_PROJECT_URL=https://veoydbjuggetxwfgryzc.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_********************
SUPABASE_MIRROR_ENABLED=true
SUPABASE_MIRROR_TABLE=cloudflare_mirror_events
SUPABASE_MIRROR_TIMEOUT_MS=10000
SUPABASE_MIRROR_RETRY_INTERVAL_MS=30000
SUPABASE_MIRROR_QUEUE_FILE=runtime/supabase-mirror-queue.jsonl

# Reference only from Supabase Connect screen (frontend/public values):
# NEXT_PUBLIC_SUPABASE_URL=https://veoydbjuggetxwfgryzc.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_********************

# Optional: comma-separated host allowlist additions for /api/health/check
HEALTH_CHECK_ALLOWED_HOSTS=

# Optional proxy guard tuning
TMDB_PROXY_RATE_LIMIT=120
TMDB_PROXY_RATE_WINDOW_MS=60000
ANILIST_PROXY_RATE_LIMIT=60
ANILIST_PROXY_RATE_WINDOW_MS=60000
CHAT_PROXY_RATE_LIMIT=120
CHAT_PROXY_RATE_WINDOW_MS=60000
DATA_PROXY_RATE_LIMIT=120
DATA_PROXY_RATE_WINDOW_MS=60000
HEALTH_CHECK_RATE_LIMIT=20
HEALTH_CHECK_RATE_WINDOW_MS=60000

PORT=8080
TMDB_API_KEY=replace-with-tmdb-api-key
CHAT_API_BASE=https://chat-api.watchbilm.org
BILM_ADMIN_EMAILS=watchbilm@gmail.com

# Optional: comma-separated host allowlist additions for /api/health/check
HEALTH_CHECK_ALLOWED_HOSTS=

# Optional proxy guard tuning
TMDB_PROXY_RATE_LIMIT=120
TMDB_PROXY_RATE_WINDOW_MS=60000
ANILIST_PROXY_RATE_LIMIT=60
ANILIST_PROXY_RATE_WINDOW_MS=60000
CHAT_PROXY_RATE_LIMIT=120
CHAT_PROXY_RATE_WINDOW_MS=60000
HEALTH_CHECK_RATE_LIMIT=20
HEALTH_CHECK_RATE_WINDOW_MS=60000
